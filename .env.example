NODE_ENV=production
HOST=0.0.0.0
PORT=3001
APP_PORT=3001

# Compose Postgres. Override DATABASE_URL if using an external managed database.
POSTGRES_DB=paddockindia
POSTGRES_USER=paddockindia
POSTGRES_PASSWORD=change-this-password
POSTGRES_PORT=5432
DATABASE_URL=
DATABASE_SSL=false
RUN_MIGRATIONS_ON_START=true
REQUIRE_DATABASE=false

# Auth/bootstrap. Comma-separate emails that should become super admins on signup.
SUPER_ADMIN_EMAILS=
SESSION_COOKIE_NAME=paddockindia_session
CSRF_COOKIE_NAME=paddockindia_csrf
COOKIE_SECURE=true

# SMTP. Keep secrets in Dokploy/Fly/env only; never commit real credentials.
REQUIRE_SMTP=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SEND_TIMEOUT_MS=10000
MAIL_FROM="Paddock India <no-reply@paddockindia.local>"
